{
  "name": "vendorbridge-monorepo",
  "version": "1.0.0",
  "description": "VendorBridge Enterprise Monorepo Workspace",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/frontend",
    "apps/backend",
    "packages/shared",
    "packages/constants",
    "packages/validators",
    "packages/types"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=@vendorbridge/frontend\" \"npm run dev --workspace=@vendorbridge/backend\"",
    "build": "npm run build --workspaces --if-present",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{js,jsx,json,md,css,prisma}\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "eslint": "^9.4.0",
    "prettier": "^3.3.0",
    "eslint-plugin-react": "^7.34.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "globals": "^15.3.0",
    "@eslint/js": "^9.4.0"
  }
}
