{
  "name": "vendorbridge-monorepo",
  "version": "1.0.0",
  "description": "VendorBridge Enterprise Monorepo Workspace",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/frontend",
    "apps/backend",
    "packages/shared",
    "packages/constants",
    "packages/validators",
    "packages/types"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=@vendorbridge/frontend\" \"npm run dev --workspace=@vendorbridge/backend\"",
    "build": "npm run build --workspaces --if-present",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{js,jsx,json,md,css,prisma}\""
  },
  "dependencies": {
    "@vendorbridge/frontend": "*",
    "@vendorbridge/backend": "*",
    "@vendorbridge/shared": "*",
    "@vendorbridge/constants": "*",
    "@vendorbridge/validators": "*",
    "@vendorbridge/types": "*",
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "express-rate-limit": "^7.2.0",
    "cookie-parser": "^1.4.6",
    "compression": "^1.7.4",
    "jsonwebtoken": "^9.0.2",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8",
    "@prisma/client": "^5.14.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^6.23.1",
    "axios": "^1.7.2",
    "react-hook-form": "^7.51.5",
    "@hookform/resolvers": "^3.6.0",
    "lucide-react": "^0.395.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.3.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "eslint": "^9.4.0",
    "prettier": "^3.3.0",
    "eslint-plugin-react": "^7.34.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "globals": "^15.3.0",
    "@eslint/js": "^9.4.0",
    "nodemon": "^3.1.2",
    "prisma": "^5.14.0",
    "tailwindcss": "^3.4.3",
    "postcss": "^8.4.38",
    "autoprefixer": "^10.4.19",
    "vite": "^5.2.11",
    "@vitejs/plugin-react": "^4.3.0"
  }
}
